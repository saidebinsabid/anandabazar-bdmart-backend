# ═════════════════════════════════════════════════════════════════════
#   Anandabazar BDMart — BACKEND environment variables
# ═════════════════════════════════════════════════════════════════════
# HOW TO USE
#   • Local dev : copy this file to `.env` and fill the values.
#   • Render    : add each variable under
#                 Service → Environment (or bulk-paste render.env).
#                 (do NOT commit `.env` — it is gitignored.)
#
# Legend:  [REQUIRED] must be set   ·   [optional] safe to leave blank
#
# ✅  DEPLOY TARGET = RENDER (long-running Node), NOT Vercel serverless — so
#     Socket.IO real-time push AND the courier auto-sync cron BOTH work here.
#     Use Cloudinary for image uploads (Render's disk is ephemeral across deploys).
# ═════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development          # local only — Render sets this to "production"
PORT=5000                     # local only — Render provides PORT automatically

# ── Database — MongoDB Atlas ─────────────────────────────────────────
# [REQUIRED] full SRV string including the database name at the end.
DATABASE_URL=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/anandabazar-bdmart?appName=Cluster0

# ── JWT (authentication) ─────────────────────────────────────────────
# [REQUIRED] use long random strings, e.g.  openssl rand -hex 48
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Public URLs ──────────────────────────────────────────────────────
# [REQUIRED] deployed client URL (used for CORS + email links).
FRONTEND_URL=https://your-client.vercel.app
# [optional] public URL of THIS backend (builds absolute URLs for disk-stored
# uploads). With Cloudinary you can leave this blank.
BACKEND_URL=https://your-backend.onrender.com

# ── Cloudinary — image / product uploads ─────────────────────────────
# [REQUIRED on Vercel] free account at https://cloudinary.com → Dashboard.
# Without these, product image uploads will NOT persist on serverless hosting.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email / SMTP ─────────────────────────────────────────────────────
# [optional] blank = verification/invoice emails are logged, not sent.
# To send for real, use a Gmail address + App Password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@anandabazarbdmart.com

# ── Google OAuth — "Sign in with Google" ─────────────────────────────
# [optional] client_id must match the client's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Payment: bKash ───────────────────────────────────────────────────
# [optional] blank = sandbox. Fill with live merchant creds to go live.
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_SANDBOX=true

# ── Payment: SSLCommerz (bKash + Nagad + card aggregator) ────────────
# [optional] blank = sandbox. Easiest way to accept bKash + Nagad + cards.
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWD=
SSLCZ_SANDBOX=true

# Base URLs used to build payment-gateway callback / redirect links.
PAYMENT_BACKEND_URL=https://your-backend.onrender.com
PAYMENT_FRONTEND_URL=https://your-client.vercel.app

# ── Steadfast courier (Packzy) — delivery booking / COD ──────────────
# [optional]
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_WEBHOOK_SECRET=
# Auto status-sync cron works on Render — set "true" to enable periodic sync.
STEADFAST_AUTO_SYNC=false
STEADFAST_AUTO_SYNC_MINUTES=30

# ── Payment: Nagad ───────────────────────────────────────────────────
# [optional] blank = dev-simulation. Fill keys + set NAGAD_LIVE=true to go live.
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=https://sandbox-ssl.mynagad.com/api/dfs
NAGAD_SANDBOX=true
NAGAD_LIVE=false

# ── Payment: Rocket (DBBL) ───────────────────────────────────────────
# [optional] blank = dev-simulation. Fill keys + set ROCKET_LIVE=true to go live.
ROCKET_MERCHANT_ID=
ROCKET_API_KEY=
ROCKET_API_SECRET=
ROCKET_BASE_URL=
ROCKET_SANDBOX=true
ROCKET_LIVE=false
